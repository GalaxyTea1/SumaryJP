# Runtime
NODE_ENV=development
PORT=3000

# Security
JWT_SECRET=replace_with_a_long_random_secret

# CORS
FRONTEND_URL=http://localhost:5500

# Option 1: hosted PostgreSQL, for example Supabase.
# Leave empty when using the local DB_* settings below.
DATABASE_URL=
DB_SSL=true

# Option 2: local PostgreSQL.
# Used when DATABASE_URL is empty.
DB_USER=postgres
DB_HOST=localhost
DB_NAME=sumaryjp
DB_PASSWORD=postgres
DB_PORT=5432
